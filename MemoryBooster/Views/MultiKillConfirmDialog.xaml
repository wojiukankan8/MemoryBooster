<Window x:Class="MemoryBooster.Views.MultiKillConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" Width="380" Height="360">
    <Border CornerRadius="10" Background="White" BorderBrush="#E04848" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.45" ShadowDepth="2" Color="#000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#E04848" CornerRadius="8,8,0,0">
                <StackPanel Orientation="Horizontal" Margin="16,12">
                    <TextBlock Text="&#x26A0;" FontSize="22" Foreground="White"
                               FontFamily="Segoe UI Symbol" Margin="0,0,10,0"/>
                    <TextBlock Text="&#x5371;&#x9669;&#x64CD;&#x4F5C;&#x786E;&#x8BA4;"
                               FontFamily="Microsoft YaHei" FontSize="16"
                               FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Warning text -->
            <TextBlock Grid.Row="1" x:Name="TxtWarn"
                       FontFamily="Microsoft YaHei" FontSize="13" Foreground="#C62222"
                       FontWeight="Bold" Margin="16,14,16,6"
                       TextWrapping="Wrap"/>

            <!-- Process list -->
            <Border Grid.Row="2" Margin="16,0,16,6"
                    BorderBrush="#F0C8C8" BorderThickness="1" Background="#FFF8F8"
                    CornerRadius="4">
                <ListBox x:Name="ProcList" Background="Transparent" BorderThickness="0"
                         FontFamily="Microsoft YaHei" FontSize="12" Foreground="#333"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" Grid.Column="0"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Pid, StringFormat=PID {0}}"
                                           Grid.Column="1" Foreground="#999"
                                           Margin="8,0,4,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="16,6,16,14">
                <Button Content="&#x53D6;&#x6D88;" Width="80" Height="30" Margin="0,0,10,0"
                        Click="OnCancel" Background="#EEEEEE" Foreground="#333"
                        FontFamily="Microsoft YaHei" BorderBrush="#CCC" Cursor="Hand"/>
                <Button Content="&#x786E;&#x8BA4;&#x5F3A;&#x5236;&#x7ED3;&#x675F;" Width="120" Height="30"
                        Click="OnConfirm" Background="#E04848" Foreground="White"
                        FontFamily="Microsoft YaHei" FontWeight="Bold"
                        BorderBrush="#C62222" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
