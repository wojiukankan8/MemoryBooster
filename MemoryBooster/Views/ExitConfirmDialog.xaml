<Window x:Class="MemoryBooster.Views.ExitConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" Width="340" Height="210">
    <Border CornerRadius="10" Background="White" BorderBrush="#2B95D6" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.4" ShadowDepth="2" Color="#000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="8,8,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2B95D6" Offset="0"/>
                        <GradientStop Color="#23B574" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="&#x786E;&#x8BA4;&#x9000;&#x51FA;"
                           FontFamily="Microsoft YaHei" FontSize="15"
                           FontWeight="Bold" Foreground="White" Margin="16,12"/>
            </Border>

            <TextBlock Grid.Row="1" Margin="20,20,20,10"
                       FontFamily="Microsoft YaHei" FontSize="13" Foreground="#444"
                       TextWrapping="Wrap"
                       Text="&#x9700;&#x8981;&#x9000;&#x51FA;&#x7A0B;&#x5E8F;&#xFF0C;&#x8FD8;&#x662F;&#x6700;&#x5C0F;&#x5316;&#x5230;&#x7CFB;&#x7EDF;&#x6258;&#x76D8;&#xFF1F;&#x000A;&#x6700;&#x5C0F;&#x5316;&#x540E;&#x52A0;&#x901F;&#x5668;&#x4ECD;&#x5728;&#x540E;&#x53F0;&#x8FD0;&#x884C;&#xFF0C;&#x53EF;&#x4ECE;&#x6258;&#x76D8;&#x56FE;&#x6807;&#x6062;&#x590D;&#x3002;"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="16,0,16,14">
                <Button Content="&#x53D6;&#x6D88;" Width="70" Height="30" Margin="0,0,8,0"
                        Click="OnCancel" Background="#EEEEEE" Foreground="#333"
                        FontFamily="Microsoft YaHei" BorderBrush="#CCC" Cursor="Hand"/>
                <Button Content="&#x6700;&#x5C0F;&#x5316;&#x5230;&#x6258;&#x76D8;" Width="110" Height="30" Margin="0,0,8,0"
                        Click="OnMinimize" Background="#2B95D6" Foreground="White"
                        FontFamily="Microsoft YaHei" FontWeight="Bold"
                        BorderBrush="#1C6FB0" Cursor="Hand"/>
                <Button Content="&#x9000;&#x51FA;&#x7A0B;&#x5E8F;" Width="90" Height="30"
                        Click="OnExit" Background="#E04848" Foreground="White"
                        FontFamily="Microsoft YaHei" FontWeight="Bold"
                        BorderBrush="#C62222" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
