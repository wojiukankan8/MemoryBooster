<Window x:Class="MemoryBooster.Views.BoosterPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Width="340" Height="580">
    <Window.Resources>
        <!-- Bottom tab radio button style -->
        <Style x:Key="BottomTab" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" Padding="0,8" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="Icon" Text="{TemplateBinding Tag}"
                                           FontSize="15" HorizontalAlignment="Center"
                                           Foreground="#80FFFFFF" FontFamily="Segoe UI Symbol"/>
                                <TextBlock x:Name="Tb" Text="{TemplateBinding Content}"
                                           FontSize="11" HorizontalAlignment="Center"
                                           Foreground="#80FFFFFF" FontFamily="Microsoft YaHei" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                                <Setter TargetName="Icon" Property="Foreground" Value="White"/>
                                <Setter TargetName="Tb" Property="Foreground" Value="White"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Green rounded button -->
        <Style x:Key="BoostBtn" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="18" Padding="20,8" Cursor="Hand"
                                BorderBrush="#80FFFFFF" BorderThickness="1.5" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}"
                                       Foreground="White" FontSize="16" FontWeight="Bold"
                                       FontFamily="Microsoft YaHei" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Tb" Property="Foreground" Value="#80FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Small action buttons -->
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="8,3">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.45" ShadowDepth="2" Color="#000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ Header: gradient with percentage + boost button ═══ -->
            <Border x:Name="HeaderBorder" Grid.Row="0" CornerRadius="8,8,0,0" MouseLeftButtonDown="OnTitleDrag">
                <Border.Background>
                    <LinearGradientBrush x:Name="HeaderBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="HeaderStop1" Color="#2B95D6" Offset="0"/>
                        <GradientStop x:Name="HeaderStop2" Color="#23B574" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Title row -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="14,10,0,0">
                        <Ellipse Width="18" Height="18" Margin="0,0,6,0">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.3,0.3">
                                    <GradientStop Color="#66FF66" Offset="0"/>
                                    <GradientStop Color="#228833" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="&#x5185;&#x5B58;&#x52A0;&#x901F;&#x5668;" Foreground="White"
                                   FontSize="13" FontWeight="Bold" FontFamily="Microsoft YaHei"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Status label (top-right, above percentage) -->
                    <Border x:Name="MemStatusBadge" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,36,14,0" Background="#33FFFFFF" CornerRadius="10" Padding="8,3">
                        <TextBlock x:Name="TxtMemStatus" Text="&#x7535;&#x8111;&#x5145;&#x6EE1;&#x6D3B;&#x529B;"
                                   Foreground="White" FontSize="11"
                                   FontFamily="Microsoft YaHei"/>
                    </Border>
                    <!-- Close button -->
                    <Button Content="&#xD7;" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,6,10,0" Click="OnClose"
                            Background="Transparent" Foreground="#B0FFFFFF" FontSize="18"
                            BorderThickness="0" Cursor="Hand" Width="24" Height="24"/>

                    <!-- Big percentage + boost -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="0,44,0,18">
                        <StackPanel Margin="0,0,24,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtMemPct" Text="0" Foreground="White"
                                           FontSize="52" FontWeight="Bold" FontFamily="Segoe UI"
                                           VerticalAlignment="Bottom" Margin="0,0,2,0"/>
                                <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,10">
                                    <TextBlock Text="%" Foreground="#D0FFFFFF" FontSize="18"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock Text="&#x5DF2;&#x7528;" Foreground="#B0FFFFFF"
                                               FontSize="11" FontFamily="Microsoft YaHei"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="BtnBoost" Content="&#x4E00;&#x952E;&#x52A0;&#x901F;"
                                Style="{StaticResource BoostBtn}" Click="OnOneClickBoost"
                                VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Memory detail -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Bottom" Margin="14,0,0,8">
                        <TextBlock x:Name="TxtMemInfo" Text="" Foreground="#90FFFFFF"
                                   FontSize="10" FontFamily="Microsoft YaHei"/>
                        <TextBlock x:Name="TxtMemDetail" Text="" Foreground="#70FFFFFF"
                                   FontSize="10" FontFamily="Microsoft YaHei" Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Content area ═══ -->
            <Grid Grid.Row="1" Background="#F5F5F5">
                <!-- Process Tab -->
                <Grid x:Name="ProcessPanel">
                    <Grid.Resources>
                        <ContextMenu x:Key="RowMenu">
                            <MenuItem Header="&#x7ED3;&#x675F;&#x8FDB;&#x7A0B;" Click="OnKillFromMenu"/>
                            <Separator/>
                            <MenuItem Header="&#x6253;&#x5F00;&#x6587;&#x4EF6;&#x4F4D;&#x7F6E;" Click="OnOpenFileLocation"/>
                            <MenuItem Header="&#x590D;&#x5236;&#x8DEF;&#x5F84;" Click="OnCopyFilePath"/>
                        </ContextMenu>
                        <Style x:Key="ProcHdrStyle" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F4F7FA"/>
                            <Setter Property="Foreground" Value="#555"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontFamily" Value="Microsoft YaHei"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="BorderBrush" Value="#E0E6EC"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Height" Value="26"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                        <Style x:Key="ProcRowStyle" TargetType="DataGridRow">
                            <Setter Property="ContextMenu" Value="{StaticResource RowMenu}"/>
                            <Style.Triggers>
                                <!-- Divider line on the row that marks fg/bg section break -->
                                <DataTrigger Binding="{Binding IsSectionBreak}" Value="True">
                                    <Setter Property="BorderBrush" Value="#DDE8F2"/>
                                    <Setter Property="BorderThickness" Value="0,2,0,0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style x:Key="ProcCellStyle" TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <!-- Red highlight makes the user's click target stand out
                                     and is preserved across the 2s auto-refresh tick. -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFECEC"/>
                                    <Setter Property="Foreground" Value="#C62828"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <DataTemplate x:Key="NameCellTemplate">
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding FilePath}" FontSize="10"
                                           Foreground="#999"
                                           Visibility="{Binding PathVisibility}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- List header -->
                    <Border Grid.Row="0" Background="White" Padding="14,8" BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="&#x53EF;&#x9009;&#x62E9;&#x5173;&#x95ED;&#x7684;&#x7A0B;&#x5E8F;"
                                       Foreground="#333" FontSize="12" FontWeight="Bold"
                                       FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTotalMem" Text="" Foreground="#2B95D6"
                                       FontSize="12" FontFamily="Segoe UI"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Search & options row -->
                    <Border Grid.Row="1" Background="White" Padding="10,4,10,6"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" x:Name="CmbProcSort"
                                      Width="108" Height="22"
                                      FontSize="11" FontFamily="Microsoft YaHei"
                                      VerticalContentAlignment="Center"
                                      SelectedIndex="0"
                                      SelectionChanged="OnProcessSortChanged">
                                <ComboBoxItem Content="&#x6309;&#x5185;&#x5B58;&#x4F7F;&#x7528;&#x7387;"/>
                                <ComboBoxItem Content="&#x6309;CPU&#x4F7F;&#x7528;&#x7387;"/>
                                <ComboBoxItem Content="&#x6309;&#x8FDB;&#x7A0B;&#x540D;&#x79F0;"/>
                            </ComboBox>
                            <CheckBox Grid.Column="1" x:Name="ChkShowPath"
                                      Content="&#x663E;&#x793A;&#x8DEF;&#x5F84;"
                                      Foreground="#555" FontSize="11"
                                      FontFamily="Microsoft YaHei"
                                      VerticalAlignment="Center" Margin="8,0,0,0"
                                      Checked="OnShowPathChanged" Unchecked="OnShowPathChanged"/>
                            <CheckBox Grid.Column="2" x:Name="ChkShowFg" IsChecked="True"
                                      Content="&#x663E;&#x793A;&#x524D;&#x53F0;&#x7A97;&#x53E3;&#x8FDB;&#x7A0B;"
                                      Foreground="#555" FontSize="11"
                                      FontFamily="Microsoft YaHei"
                                      VerticalAlignment="Center" Margin="8,0,0,0"
                                      Checked="OnShowFgChanged" Unchecked="OnShowFgChanged"/>
                        </Grid>
                    </Border>

                    <!-- Unified process list — background-by-default; a divider
                         line separates foreground rows above from background
                         rows below (no CollectionViewSource grouping: that
                         caused virtualization crashes when scrolling). -->
                    <DataGrid x:Name="ProcessGrid" Grid.Row="2" Margin="0"
                              AutoGenerateColumns="False" IsReadOnly="False"
                              Background="White" BorderThickness="0"
                              RowBackground="White" AlternatingRowBackground="#FAFAFA"
                              HeadersVisibility="Column" GridLinesVisibility="None"
                              FontFamily="Microsoft YaHei" FontSize="12"
                              Foreground="#333" CanUserResizeRows="False"
                              CanUserSortColumns="True"
                              SelectionMode="Single" SelectedCellsChanged="OnProcessSelected"
                              EnableRowVirtualization="True" EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              VirtualizingPanel.CacheLengthUnit="Item"
                              VirtualizingPanel.CacheLength="8,16"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.IsDeferredScrollingEnabled="True"
                              RowHeight="32" HorizontalScrollBarVisibility="Disabled"
                              ColumnHeaderStyle="{StaticResource ProcHdrStyle}"
                              RowStyle="{StaticResource ProcRowStyle}"
                              CellStyle="{StaticResource ProcCellStyle}">
                        <DataGrid.Resources>
                            <ContextMenu x:Key="RowMenuInner">
                                <MenuItem Header="&#x6253;&#x5F00;&#x6587;&#x4EF6;&#x4F4D;&#x7F6E;" Click="OnOpenFileLocation"/>
                                <MenuItem Header="&#x590D;&#x5236;&#x8DEF;&#x5F84;" Click="OnCopyFilePath"/>
                            </ContextMenu>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="&#x7A0B;&#x5E8F;&#x540D;&#x79F0;" Width="*" IsReadOnly="True"
                                                    SortMemberPath="DisplayName"
                                                    CellTemplate="{StaticResource NameCellTemplate}"/>
                            <DataGridTextColumn Header="CPU" Binding="{Binding CpuDisplay}"
                                                SortMemberPath="CpuPercent" Width="60" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#2B95D6"/>
                                        <Setter Property="Margin" Value="0,0,10,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="&#x5185;&#x5B58;" Binding="{Binding WorkingSetDisplay}"
                                                SortMemberPath="WorkingSet" Width="75" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#888"/>
                                        <Setter Property="Margin" Value="0,0,14,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridCheckBoxColumn Header="" CanUserSort="False"
                                                    Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="36">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Bottom actions (search on the left, buttons on the right) -->
                    <Border Grid.Row="3" Background="White" Padding="10,6" BorderBrush="#E0E0E0"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#F5F5F5" CornerRadius="3"
                                    BorderBrush="#D5D5D5" BorderThickness="1"
                                    HorizontalAlignment="Left" Width="180" Height="24">
                                <Grid>
                                    <TextBlock Text="&#x1F50D; &#x641C;&#x7D22;&#x8FDB;&#x7A0B;&#x540D;..."
                                               Foreground="#AAA" FontSize="11"
                                               FontFamily="Microsoft YaHei"
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               x:Name="TxtSearchHint" IsHitTestVisible="False"/>
                                    <TextBox x:Name="TxtSearch" Background="Transparent"
                                             BorderThickness="0" FontSize="11" Padding="8,2"
                                             Foreground="#333" FontFamily="Microsoft YaHei"
                                             VerticalAlignment="Center"
                                             TextChanged="OnSearchChanged"/>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="TxtSelCount" Text="" Foreground="#999"
                                           FontSize="11" FontFamily="Microsoft YaHei"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button x:Name="BtnCleanProc" Content="&#x6E05;&#x7406;&#x5185;&#x5B58;"
                                        Background="#2B95D6" Style="{StaticResource SmallBtn}"
                                        Margin="0,0,6,0" Click="OnCleanProcess" IsEnabled="False"/>
                                <Button x:Name="BtnKillProc" Content="&#x7ED3;&#x675F;&#x8FDB;&#x7A0B;"
                                        Background="#E04848" Style="{StaticResource SmallBtn}"
                                        Click="OnKillProcess" IsEnabled="False"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Network Tab -->
                <Grid x:Name="NetworkPanel" Visibility="Collapsed" Background="#F5F5F5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Big-speed header -->
                    <Border Grid.Row="0" Margin="12,12,12,6" Padding="14,10"
                            Background="White" CornerRadius="8"
                            BorderBrush="#E0EBF5" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#x2193;" Foreground="#23B574" FontSize="18" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="TxtDlSpeed" Text="0 B/s"
                                               Foreground="#23B574" FontSize="22" FontWeight="Bold"
                                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="&#x4E0B;&#x8F7D;" Foreground="#AAA" FontSize="10"
                                           HorizontalAlignment="Center"
                                           FontFamily="Microsoft YaHei"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#x2191;" Foreground="#2B95D6" FontSize="18" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="TxtUlSpeed" Text="0 B/s"
                                               Foreground="#2B95D6" FontSize="22" FontWeight="Bold"
                                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="&#x4E0A;&#x4F20;" Foreground="#AAA" FontSize="10"
                                           HorizontalAlignment="Center"
                                           FontFamily="Microsoft YaHei"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Totals -->
                    <Grid Grid.Row="1" Margin="16,0,16,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#x603B;&#x4E0B;&#x8F7D;:" Foreground="#999" FontSize="11"
                                       FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTotalDl" Text="0 B" Foreground="#555" FontSize="11"
                                       FontFamily="Segoe UI" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="&#x603B;&#x4E0A;&#x4F20;:" Foreground="#999" FontSize="11"
                                       FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTotalUl" Text="0 B" Foreground="#555" FontSize="11"
                                       FontFamily="Segoe UI" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Section header + sort combo -->
                    <Grid Grid.Row="2" Margin="16,6,16,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkEnableNet"
                                  Content="&#x76D1;&#x89C6;" Foreground="#2B95D6"
                                  FontSize="11" FontFamily="Microsoft YaHei"
                                  FontWeight="Bold" VerticalAlignment="Center"
                                  Checked="OnEnableNetChanged" Unchecked="OnEnableNetChanged"/>
                        <TextBlock Grid.Column="1" Text="&#x6B63;&#x5728;&#x8BBF;&#x95EE;&#x7F51;&#x7EDC;&#x7684;&#x8FDB;&#x7A0B;"
                                   Foreground="#555" FontSize="12" FontWeight="Bold"
                                   FontFamily="Microsoft YaHei" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="&#x6392;&#x5E8F;:" Foreground="#999" FontSize="11"
                                       FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox x:Name="CmbNetSort" Width="88" Height="22" FontSize="11"
                                      FontFamily="Microsoft YaHei" SelectionChanged="OnNetSortChanged"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="&#x603B;&#x901F;&#x7387;" IsSelected="True"/>
                                <ComboBoxItem Content="&#x4E0A;&#x4F20;"/>
                                <ComboBoxItem Content="&#x4E0B;&#x8F7D;"/>
                                <ComboBoxItem Content="&#x8FDE;&#x63A5;&#x6570;"/>
                                <ComboBoxItem Content="&#x540D;&#x79F0;"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="NetProcGrid" Grid.Row="3" Margin="10,0,10,10"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="White" BorderThickness="1" BorderBrush="#E0E0E0"
                              RowBackground="White" AlternatingRowBackground="#FAFAFA"
                              HeadersVisibility="Column" GridLinesVisibility="None"
                              FontFamily="Microsoft YaHei" FontSize="11"
                              Foreground="#444" RowHeight="30"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              HorizontalScrollBarVisibility="Disabled"
                              CanUserResizeColumns="False" CanUserReorderColumns="False"
                              CanUserSortColumns="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F4F7FA"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="FontFamily" Value="Microsoft YaHei"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="BorderBrush" Value="#E0E6EC"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Height" Value="22"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="&#x8FDB;&#x7A0B;" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#333" FontSize="11"/>
                                            <TextBlock Text="{Binding Pid, StringFormat=PID {0}}"
                                                       Foreground="#AAA" FontSize="9" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="&#x2191; &#x4E0A;&#x4F20;" Binding="{Binding UpDisplay}" Width="74">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#2B95D6"/>
                                        <Setter Property="Margin" Value="0,0,6,0"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="&#x2193; &#x4E0B;&#x8F7D;" Binding="{Binding DownDisplay}" Width="74">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#23B574"/>
                                        <Setter Property="Margin" Value="0,0,6,0"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="&#x72B6;&#x6001;" Width="44">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusColor}" CornerRadius="8"
                                                Padding="6,1" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding Status}" Foreground="White"
                                                       FontSize="10" FontFamily="Microsoft YaHei"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
