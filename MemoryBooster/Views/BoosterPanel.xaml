                            </StackPanel>
                        </Border>

                        <Border Background="#F8FBFF" CornerRadius="8" Padding="14,10"
                                Margin="0,0,0,8" BorderBrush="#E0EBF5" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="&#x76AE;&#x80A4;&#x4E3B;&#x9898;"
                                           Foreground="#333" FontSize="13"
                                           FontFamily="Microsoft YaHei" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <RadioButton x:Name="SkinDefault" Content="&#x9ED8;&#x8BA4;"
                                                 Foreground="#333" GroupName="Skin"
                                                 IsChecked="True" Margin="0,0,12,4"
                                                 Checked="OnSkinChanged"/>
                                    <RadioButton x:Name="SkinBlue" Content="&#x84DD;&#x8272;"
                                                 Foreground="#2B95D6" GroupName="Skin"
                                                 Margin="0,0,12,4"
                                                 Checked="OnSkinChanged"/>
                                    <RadioButton x:Name="SkinPurple" Content="&#x7D2B;&#x8272;"
                                                 Foreground="#8855CC" GroupName="Skin"
                                                 Margin="0,0,12,4"
                                                 Checked="OnSkinChanged"/>
                                    <RadioButton x:Name="SkinDark" Content="&#x6697;&#x8272;"
                                                 Foreground="#333" GroupName="Skin"
                                                 Margin="0,0,12,4"
                                                 Checked="OnSkinChanged"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#F8FBFF" CornerRadius="8" Padding="14,10"
                                Margin="0,0,0,8" BorderBrush="#E0EBF5" BorderThickness="1">
                            <Grid>
                                <TextBlock Text="&#x9000;&#x51FA;&#x65F6;&#x6700;&#x5C0F;&#x5316;&#x5230;&#x6258;&#x76D8;"
                                           Foreground="#333" FontSize="13"
                                           FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
                                <CheckBox x:Name="ChkMinToTray" HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Checked="OnMinToTrayChanged" Unchecked="OnMinToTrayChanged"/>
                            </Grid>
                        </Border>

                        <!-- Exit (moved above About) -->
                        <Button Content="&#x9000;&#x51FA;&#x7A0B;&#x5E8F;" Click="OnExitApp"
                                Background="#E8E8E8" Foreground="#D9534F" FontSize="13"
