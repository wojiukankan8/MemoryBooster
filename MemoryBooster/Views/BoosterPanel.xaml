                                <TextBlock Text="Memory Booster v2.0&#x000A;&#x5185;&#x5B58;&#x6E05;&#x7406;&#x52A0;&#x901F;&#x5DE5;&#x5177;&#x0020;2.0"
                                           Foreground="#999" FontSize="11"
                                           FontFamily="Microsoft YaHei" Margin="0,4,0,0"/>
