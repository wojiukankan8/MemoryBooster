                            <TextBlock Text="&#x542F;&#x7528;&#x540E;&#x5C06;&#x91C7;&#x96C6;&#x6BCF;&#x4E2A;&#x8FDB;&#x7A0B;&#x7684;&#x4E0A;&#x4E0B;&#x884C;&#x901F;&#x7387;&#x3002;&#x9ED8;&#x8BA4;&#x5173;&#x95ED;&#x4EE5;&#x8282;&#x7701;&#x5185;&#x5B58;&#x4E0E; CPU&#x3002;"
                                       Foreground="#999" FontSize="11" TextWrapping="Wrap"
                                       FontFamily="Microsoft YaHei" HorizontalAlignment="Center"
                                       TextAlignment="Center" Margin="0,10,0,14"/>
                            <Button Content="&#x542F;&#x7528;&#x7F51;&#x7EDC;&#x76D1;&#x89C6;"
                                    Background="#2B95D6" Foreground="White"
                                    FontFamily="Microsoft YaHei" FontSize="12"
                                    BorderThickness="0" Padding="16,6" Cursor="Hand"
                                    HorizontalAlignment="Center"
                                    Click="OnEnableNetFromOverlay"/>
