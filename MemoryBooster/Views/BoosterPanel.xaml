                    </Border>
                </Grid>

                <!-- Settings Tab -->
                <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" Background="White">
                    <StackPanel Margin="16,14,16,14">
                        <Border Background="#F8FBFF" CornerRadius="8" Padding="14,10"
                                Margin="0,0,0,8" BorderBrush="#E0EBF5" BorderThickness="1">
                            <Grid>
                                <TextBlock Text="&#x5F00;&#x673A;&#x81EA;&#x52A8;&#x542F;&#x52A8;"
                                           Foreground="#333" FontSize="13"
                                           FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
                                <CheckBox x:Name="ChkAutoStart" HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Checked="OnAutoStartChanged" Unchecked="OnAutoStartChanged"/>
                            </Grid>
                        </Border>

                        <Border Background="#F8FBFF" CornerRadius="8" Padding="14,10"
                                Margin="0,0,0,8" BorderBrush="#E0EBF5" BorderThickness="1">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="&#x81EA;&#x52A8;&#x6E05;&#x7406;&#x5185;&#x5B58;"
                                               Foreground="#333" FontSize="13"
                                               FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkAutoClean" HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Checked="OnAutoCleanChanged" Unchecked="OnAutoCleanChanged"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="&#x95F4;&#x9694;(&#x5206;&#x949F;):"
                                               Foreground="#888" FontSize="11" VerticalAlignment="Center"
                                               FontFamily="Microsoft YaHei"/>
                                    <TextBox x:Name="TxtInterval" Width="50" Margin="6,0,0,0"
                                             Background="White" Foreground="#333" BorderBrush="#CCC"
                                             FontSize="12" Padding="4,2"
                                             TextChanged="OnIntervalChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#F8FBFF" CornerRadius="8" Padding="14,10"
                                Margin="0,0,0,8" BorderBrush="#E0EBF5" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="&#x52A0;&#x901F;&#x7403;&#x900F;&#x660E;&#x5EA6;"
                                           Foreground="#333" FontSize="13"
                                           FontFamily="Microsoft YaHei"/>
