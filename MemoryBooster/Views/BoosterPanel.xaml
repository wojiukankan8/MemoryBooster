                        <GradientStop x:Name="FooterStop2" Color="#23B574" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="TabProcess" Grid.Column="0"
                                 Content="&#x52A0;&#x901F;" Tag="&#x26A1;"
                                 Style="{StaticResource BottomTab}" IsChecked="True"
                                 Checked="TabChanged" GroupName="Tabs"/>
                    <RadioButton x:Name="TabNetwork" Grid.Column="1"
                                 Content="&#x7F51;&#x901F;" Tag="&#x21C5;"
