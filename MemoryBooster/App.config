<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
    <runtime>
        <!-- Server GC + concurrent compaction noticeably reduces allocation pauses
             for a long-lived tray utility and keeps committed memory lower. -->
        <gcServer enabled="false" />
        <gcConcurrent enabled="true" />
        <GCLatencyMode>Interactive</GCLatencyMode>
    </runtime>
</configuration>
